ENVIRONMENT=production
BROKER=dhan
PAPER_TRADING_ONLY=true

# --- Set these in Render dashboard (never commit real values) ---
# Use Session pooler (port 5432, host contains pooler.supabase.com). SSL is added automatically in code.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=
API_KEY=choose-a-long-random-secret

# Your Vercel URL (update after first Vercel deploy)
CORS_ORIGINS=https://your-app.vercel.app

TICK_INTERVAL_SECONDS=2.5
