ENVIRONMENT=production
BROKER=dhan
PAPER_TRADING_ONLY=true

# --- Set these in Render dashboard (never commit real values) ---
# Easiest: put host/user in DATABASE_URL and password in DATABASE_PASSWORD (avoids @/# issues).
DATABASE_URL=postgresql://postgres.PROJECT_REF@aws-0-REGION.pooler.supabase.com:5432/postgres
DATABASE_PASSWORD=your-db-password-here
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=
API_KEY=choose-a-long-random-secret

# Your Vercel URL (update after first Vercel deploy)
CORS_ORIGINS=https://your-app.vercel.app

TICK_INTERVAL_SECONDS=2.5
